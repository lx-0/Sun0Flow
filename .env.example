DATABASE_URL="postgres://projects:projects@localhost:5433/sunoflow"
SUNOFLOW_DATABASE_URL="postgres://projects:projects@localhost:5433/sunoflow"

AUTH_SECRET="" # Generate with: npx auth secret
AUTH_URL="http://localhost:3000"

# Suno API key from sunoapi.org — required for music generation.
# Users can also set their own key in Settings > API Key.
# If omitted, the app falls back to mock/demo data.
SUNOAPI_KEY=""

# Mailjet email delivery (optional — falls back to console.log without these)
# MAILJET_API_KEY=""
# MAILJET_SECRET_KEY=""
# EMAIL_FROM="noreply@sunoflow.com"

# OpenAI API key — required for LLM text generation (lyrics, etc.)
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini" # Optional: override default model

# Google OAuth (optional — sign-in button hidden when empty)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
